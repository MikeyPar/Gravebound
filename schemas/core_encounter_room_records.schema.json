{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CoreEncounterRoomRecords",
  "description": "Complete strict authoring set for the first `GB-M03-03D` compiler layer.",
  "type": "object",
  "properties": {
    "authored_behaviors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreAuthoredEnemyBehaviorRecord"
      }
    },
    "authored_patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreAuthoredPatternRecord"
      }
    },
    "layouts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreFixedLayoutRecord"
      }
    },
    "packs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreEncounterPackRecord"
      }
    },
    "rooms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreRoomTemplateRecord"
      }
    },
    "roster": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/CoreEncounterRosterMember"
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "roster",
    "authored_behaviors",
    "authored_patterns",
    "rooms",
    "packs",
    "layouts"
  ],
  "$defs": {
    "ContentId": {
      "description": "Stable dot-separated content identifier.",
      "type": "string"
    },
    "CoreAttackGroupRule": {
      "type": "string",
      "enum": [
        "distinct_projectile_hit_groups",
        "one_contact_hit_per_cast"
      ]
    },
    "CoreAuthoredEnemyBehaviorRecord": {
      "description": "Exact authored behavior for the five Core actors not reused from immutable FP definitions.",
      "type": "object",
      "properties": {
        "aggro_radius_milli_tiles": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "armor": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "collision_radius_milli_tiles": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "contact_damage": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "drop_reward_on_reset": {
          "type": "boolean"
        },
        "hurtbox_radius_milli_tiles": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "introduction_milliseconds": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "leash_radius_milli_tiles": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "locomotion": {
          "$ref": "#/$defs/CoreEnemyLocomotion"
        },
        "maximum_health": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "no_target_reset_milliseconds": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "owner_id": {
          "$ref": "#/$defs/ContentId"
        },
        "pattern_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ContentId"
          }
        },
        "role": {
          "$ref": "#/$defs/CoreEnemyRole"
        },
        "spawn_invulnerability_milliseconds": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "spawn_warning_milliseconds": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "state_sequence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CoreEnemyStateStage"
          }
        },
        "target_reacquire_milliseconds": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "target_selection": {
          "$ref": "#/$defs/CoreTargetSelection"
        },
        "telegraph_lock": {
          "$ref": "#/$defs/CoreTelegraphLock"
        }
      },
      "additionalProperties": false,
      "required": [
        "owner_id",
        "role",
        "state_sequence",
        "target_selection",
        "telegraph_lock",
        "maximum_health",
        "armor",
        "collision_radius_milli_tiles",
        "hurtbox_radius_milli_tiles",
        "aggro_radius_milli_tiles",
        "leash_radius_milli_tiles",
        "target_reacquire_milliseconds",
        "no_target_reset_milliseconds",
        "spawn_warning_milliseconds",
        "spawn_invulnerability_milliseconds",
        "introduction_milliseconds",
        "contact_damage",
        "drop_reward_on_reset",
        "locomotion",
        "pattern_ids"
      ]
    },
