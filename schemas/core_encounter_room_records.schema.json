        {
          "type": "object",
          "properties": {
            "geometry_kind": {
              "type": "string",
              "const": "radial_gap"
            },
            "index_count": {
              "type": "integer",
              "format": "uint16",
              "maximum": 65535,
              "minimum": 0
            },
            "omitted_adjacent_count": {
