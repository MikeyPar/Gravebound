        {
          "type": "object",
          "properties": {
            "first_offsets_milli_degrees": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            },
            "geometry_kind": {
              "type": "string",
              "const": "alternating_fan"
            },
            "projectile_radius_milli_tiles": {
              "type": "integer",
