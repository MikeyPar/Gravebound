{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssetManifest",
  "description": "Asset allowlist used to fail unresolved presentation references at build time.",
  "type": "object",
  "properties": {
    "asset_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContentId"
      }
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "asset_ids"
  ],
  "$defs": {
    "ContentId": {
      "description": "Stable dot-separated content identifier.",
      "type": "string"
    }
  }
}
