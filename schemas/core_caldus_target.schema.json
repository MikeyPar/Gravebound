      "type": "array",
      "items": {
        "$ref": "#/$defs/ContentId"
      }
    },
    "required_exit_ids": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContentId"
      }
    },
    "required_localization_keys": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ContentId"
      }
    },
